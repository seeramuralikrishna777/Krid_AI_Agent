# --- SERVER CONFIGURATION ---
HOST=0.0.0.0
PORT=8000

# --- DATABASE CONFIGURATION ---
# Leave blank to fallback to a local in-memory database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/
DB_NAME=whatsapp_agent

# --- AI & LLM PROVIDERS ---
# Provide at least one key below to use real AI reasoning.
# If both are empty, the agent runs in Simulated Rule-Based Mode.
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- META WHATSAPP BUSINESS API ---
# Provide these keys to connect to actual Meta Graph API endpoints.
# If empty, the system runs in Simulation Webhook Sandbox mode on the dashboard.
WHATSAPP_TOKEN=your_meta_system_user_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WEBHOOK_VERIFY_TOKEN=krid_ai_challenge_token_2026

# Secure Signature Verification (Optional)
# Compute payload signature using Meta App Secret to verify payload origin.
# WEBHOOK_APP_SECRET=your_meta_app_secret_here
